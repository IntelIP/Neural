# Neural SDK Configuration Template
# Copy this file to .env and fill in your actual values

# Kalshi API Configuration
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_FILE=/path/to/your/private/key/file.txt

# Alternative: Direct private key (not recommended for production)
# KALSHI_PRIVATE_KEY=your-private-key-content-here

# Trading Configuration (Optional)
# KALSHI_ENV=prod  # or 'demo' for testing
# MAX_POSITION_SIZE=1000
# RISK_LIMIT=5000

# Data Provider Configuration (Optional)
# THE_ODDS_API_KEY=your-odds-api-key-here
# S3_BUCKET_NAME=your-s3-bucket-name
# DATABASE_URL=postgresql://user:pass@localhost/dbname

# Redis Configuration (Optional - for caching)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# Logging Configuration (Optional)
# LOG_LEVEL=INFO
# LOG_FILE=/path/to/logfile.log